# q-map backends: provider profiles for q-assistant
# Usage:
# 1) copy this file to .env
# 2) keep ONE ACTIVE PROFILE block uncommented
# 3) set only the key for that provider

# ---------- Provider API Keys ----------
OPENAI_API_KEY=
OPENROUTER_API_KEY=
# Ollama usually doesn't require API key

# ---------- Active profile: OPENROUTER (project default) ----------
Q_ASSISTANT_PROVIDER=openrouter
Q_ASSISTANT_MODEL=google/gemini-3-flash-preview
Q_ASSISTANT_BASE_URL=https://openrouter.ai/api/v1
# Required for this profile: set Q_ASSISTANT_API_KEY or OPENROUTER_API_KEY.
Q_ASSISTANT_API_KEY=

# ---------- Active profile: OPENAI ----------
# Q_ASSISTANT_PROVIDER=openai
# Q_ASSISTANT_MODEL=gpt-4o-mini
# Q_ASSISTANT_BASE_URL=https://api.openai.com/v1
# Q_ASSISTANT_API_KEY=

# ---------- Active profile: OLLAMA ----------
# Q_ASSISTANT_PROVIDER=ollama
# Q_ASSISTANT_MODEL=llama3.1
# Q_ASSISTANT_BASE_URL=http://host.docker.internal:11434/api
# Q_ASSISTANT_API_KEY=

# ---------- q-assistant common ----------
Q_ASSISTANT_HOST=0.0.0.0
Q_ASSISTANT_PORT=3004
Q_ASSISTANT_CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
Q_ASSISTANT_TIMEOUT=45
Q_ASSISTANT_TEMPERATURE=0
# Q_ASSISTANT_TOP_P=1
Q_ASSISTANT_CHAT_AUDIT_ENABLED=true
Q_ASSISTANT_CHAT_AUDIT_INCLUDE_PAYLOADS=true
Q_ASSISTANT_CHAT_AUDIT_INCLUDE_CONTEXT=false

Q_ASSISTANT_PROFILE_NAME=Q-hive User
Q_ASSISTANT_PROFILE_EMAIL=user@q-hive.local
Q_ASSISTANT_PROFILE_REGISTERED_AT=2025-01-01
Q_ASSISTANT_PROFILE_COUNTRY=IT

# ---------- q-cumber cloud for MCP helper tools ----------
Q_ASSISTANT_QCUMBER_CLOUD_API_BASE=http://q-cumber-backend:3001
Q_ASSISTANT_QCUMBER_CLOUD_TOKEN=
Q_ASSISTANT_QCUMBER_CLOUD_TIMEOUT=20

# ---------- q-cumber backend ----------
QCUMBER_BACKEND_TOKEN=
QCUMBER_CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
QCUMBER_USER_NAME=Q-cumber User
QCUMBER_USER_EMAIL=qcumber@example.com

# ---------- q-storage backend ----------
QSTORAGE_API_TOKEN=
QSTORAGE_TOKEN_USERS_JSON=
QSTORAGE_USER_ID=local-user
QSTORAGE_USER_NAME=Q-storage User
QSTORAGE_USER_EMAIL=qstorage@example.com
QSTORAGE_USER_REGISTERED_AT=2026-01-01
QSTORAGE_USER_COUNTRY=IT
QSTORAGE_CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081

# ---------- optional legacy custom cloud backend ----------
QMAP_API_TOKEN=
QMAP_CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
QMAP_USER_NAME=Custom Cloud User
QMAP_USER_EMAIL=custom@example.com
