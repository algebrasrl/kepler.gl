# Optional single-token auth. If empty and no token map is provided, auth is disabled in dev mode.
QSTORAGE_API_TOKEN=

# Optional multi-user token map (JSON).
# Example:
# QSTORAGE_TOKEN_USERS_JSON=[{"token":"user-a-token","id":"user-a","name":"User A","email":"a@example.com","registeredAt":"2025-12-01","country":"IT"}]
QSTORAGE_TOKEN_USERS_JSON=

# Optional JWT claim-based auth mode (takes precedence over static token modes when enabled).
QSTORAGE_JWT_AUTH_ENABLED=false
QSTORAGE_JWT_HS256_SECRETS=
QSTORAGE_JWT_ALLOWED_ISSUERS=
QSTORAGE_JWT_ALLOWED_AUDIENCES=
QSTORAGE_JWT_REQUIRE_AUDIENCE=false
QSTORAGE_JWT_ROLES_CLAIM_PATHS=roles,realm_access.roles,resource_access.q-map.roles
QSTORAGE_JWT_ALLOWED_SUBJECTS=
QSTORAGE_JWT_READ_ROLES=
QSTORAGE_JWT_WRITE_ROLES=qmap-editor,qmap-admin

# Default user returned in dev mode (no auth).
QSTORAGE_USER_ID=local-user
QSTORAGE_USER_NAME=Q-storage User
QSTORAGE_USER_EMAIL=qstorage@example.com
QSTORAGE_USER_REGISTERED_AT=2026-01-01
QSTORAGE_USER_COUNTRY=IT

# Storage location for local JSON files.
QSTORAGE_DATA_DIR=./data

# Port and CORS.
QSTORAGE_PORT=3005
QSTORAGE_CORS_ORIGINS=http://localhost:8081,http://localhost:8082
