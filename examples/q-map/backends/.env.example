# q-assistant LLM settings
# Optional: run backend containers with host UID/GID to avoid root-owned bind-mount files
# Linux/macOS typical values can be obtained with:
#   id -u
#   id -g
QMAP_DOCKER_UID=1000
QMAP_DOCKER_GID=1000

# Kong JWT edge hardening (rendered into kong/kong.yml by `make render-kong-config`)
QMAP_KONG_JWT_PRIMARY_ISSUER=qmap-ux
QMAP_KONG_JWT_PRIMARY_SECRET=dev-secret-change-me
# Optional secondary key for zero-downtime HS256 rotation.
QMAP_KONG_JWT_SECONDARY_ISSUER=qmap-ux-next
QMAP_KONG_JWT_SECONDARY_SECRET=
# Optional comma-separated extra issuers allowed by pre-auth claim checks.
QMAP_KONG_JWT_EXTRA_ISSUERS=
QMAP_KONG_JWT_ALLOWED_AUDIENCES=q-map
QMAP_KONG_JWT_REQUIRE_AUDIENCE=true

Q_ASSISTANT_PROVIDER=openrouter
Q_ASSISTANT_MODEL=google/gemini-3-flash-preview
Q_ASSISTANT_BASE_URL=https://openrouter.ai/api/v1
# Optional chain for failover/cascade:
# format: provider|model|baseUrl,provider|model|baseUrl
# example: openrouter|google/gemini-3-flash-preview|https://openrouter.ai/api/v1,openai|gpt-4o-mini|https://api.openai.com/v1,ollama|qwen3-coder:30b|http://host.docker.internal:11434
Q_ASSISTANT_AGENT_CHAIN=
# Force explicit tool routing when user message is exactly a tool name (default true)
Q_ASSISTANT_EXPLICIT_TOOL_ROUTING=true
# Enable append-only JSONL chat audit log for debugging decision flow (default ON)
Q_ASSISTANT_CHAT_AUDIT_ENABLED=true
Q_ASSISTANT_CHAT_AUDIT_LOG_PATH=/var/log/q-assistant/chat-audit
# 0 = full-fidelity event (no compact/truncate)
Q_ASSISTANT_CHAT_AUDIT_MAX_CHARS=0
# 0 = no list slicing in sanitization
Q_ASSISTANT_CHAT_AUDIT_MAX_LIST_ITEMS=0
# 0 = no string truncation in sanitization
Q_ASSISTANT_CHAT_AUDIT_MAX_STRING_CHARS=0
# Retention safeguards for chat-audit session logs
# keep at most N session files (0 = disabled)
Q_ASSISTANT_CHAT_AUDIT_MAX_FILES=500
# keep files newer than N days (0 = disabled)
Q_ASSISTANT_CHAT_AUDIT_MAX_AGE_DAYS=30
Q_ASSISTANT_CHAT_AUDIT_INCLUDE_PAYLOADS=true
# Keep false by default to reduce context data exposure; enable only for targeted debugging.
Q_ASSISTANT_CHAT_AUDIT_INCLUDE_CONTEXT=false
# Optional: mirror each audit event to stdout JSON for external log shippers (syslog/Loki/ELK)
Q_ASSISTANT_CHAT_AUDIT_STDOUT_ENABLED=false
# Host folder bound to /var/log/q-assistant in q-assistant container
Q_ASSISTANT_AUDIT_HOST_DIR=./logs/q-assistant
# Required when Q_ASSISTANT_PROVIDER=openrouter:
# set either Q_ASSISTANT_API_KEY or OPENROUTER_API_KEY, otherwise /chat/completions and ai-eval return 401.
Q_ASSISTANT_API_KEY=
Q_ASSISTANT_ALLOW_CALLER_API_KEY_FALLBACK=false
Q_ASSISTANT_TIMEOUT=45
Q_ASSISTANT_UPSTREAM_RETRY_ATTEMPTS=2
Q_ASSISTANT_UPSTREAM_RETRY_BASE_DELAY=1.0
Q_ASSISTANT_UPSTREAM_RETRY_MAX_DELAY=8
Q_ASSISTANT_UPSTREAM_RETRY_JITTER_RATIO=0.2
Q_ASSISTANT_UPSTREAM_RETRY_TIMEOUT_INCREMENT=5
# Token budget manager (prompt window guardrails)
Q_ASSISTANT_TOKEN_BUDGET_ENABLED=true
# 0 = infer by model hint (fallback to default context below)
Q_ASSISTANT_TOKEN_BUDGET_CONTEXT_LIMIT=0
Q_ASSISTANT_TOKEN_BUDGET_DEFAULT_CONTEXT_LIMIT=128000
Q_ASSISTANT_TOKEN_BUDGET_RESERVED_OUTPUT_TOKENS=4096
Q_ASSISTANT_TOKEN_BUDGET_WARN_RATIO=0.6
Q_ASSISTANT_TOKEN_BUDGET_COMPACT_RATIO=0.75
Q_ASSISTANT_TOKEN_BUDGET_HARD_RATIO=0.94
# Optional fallback if Q_ASSISTANT_API_KEY is empty and provider=openai
OPENAI_API_KEY=
# Optional fallback if Q_ASSISTANT_API_KEY is empty and provider=openrouter
OPENROUTER_API_KEY=
# Optional OpenRouter attribution headers
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=
# Provider=ollama usually does not require API key

# Optional q-assistant profile metadata
Q_ASSISTANT_PROFILE_NAME=Q-hive User
Q_ASSISTANT_PROFILE_EMAIL=user@q-hive.local
Q_ASSISTANT_PROFILE_REGISTERED_AT=2025-01-01
Q_ASSISTANT_PROFILE_COUNTRY=IT

# q-assistant cloud map sources for MCP tools
Q_ASSISTANT_QCUMBER_CLOUD_API_BASE=http://q-cumber-backend:3001
Q_ASSISTANT_QCUMBER_CLOUD_TOKEN=
Q_ASSISTANT_QCUMBER_CLOUD_TIMEOUT=20
Q_ASSISTANT_QSTORAGE_CLOUD_API_BASE=http://q-storage-backend:3005
Q_ASSISTANT_QSTORAGE_CLOUD_TOKEN=
Q_ASSISTANT_QSTORAGE_CLOUD_TIMEOUT=20

# q-cumber cloud auth (empty = dev/no auth)
QCUMBER_BACKEND_TOKEN=
QCUMBER_JWT_AUTH_ENABLED=false
QCUMBER_JWT_HS256_SECRETS=
QCUMBER_JWT_ALLOWED_ISSUERS=
QCUMBER_JWT_ALLOWED_AUDIENCES=
QCUMBER_JWT_REQUIRE_AUDIENCE=false
QCUMBER_JWT_ROLES_CLAIM_PATHS=roles,realm_access.roles,resource_access.q-map.roles
QCUMBER_JWT_ALLOWED_SUBJECTS=
QCUMBER_JWT_READ_ROLES=
QCUMBER_POSTGIS_DSN=
# Default docker-compose service for q-cumber PostGIS (override only for external DB).
QCUMBER_POSTGIS_HOST=q-cumber-postgis
QCUMBER_POSTGIS_PORT=5432
QCUMBER_POSTGIS_DB=qvt
QCUMBER_POSTGIS_USER=qvt
QCUMBER_POSTGIS_PASSWORD=qvt
QCUMBER_POSTGIS_POOL_MIN=1
QCUMBER_POSTGIS_POOL_MAX=5
QCUMBER_WORKERS=1

# q-storage cloud auth/profile (empty = dev/no auth)
QSTORAGE_API_TOKEN=
QSTORAGE_TOKEN_USERS_JSON=
QSTORAGE_ALLOW_INSECURE_DEFAULT_USER=false
QSTORAGE_JWT_AUTH_ENABLED=false
QSTORAGE_JWT_HS256_SECRETS=
QSTORAGE_JWT_ALLOWED_ISSUERS=
QSTORAGE_JWT_ALLOWED_AUDIENCES=
QSTORAGE_JWT_REQUIRE_AUDIENCE=false
QSTORAGE_JWT_ROLES_CLAIM_PATHS=roles,realm_access.roles,resource_access.q-map.roles
QSTORAGE_JWT_ALLOWED_SUBJECTS=
QSTORAGE_JWT_READ_ROLES=
QSTORAGE_JWT_WRITE_ROLES=qmap-editor,qmap-admin
QSTORAGE_USER_ID=local-user
QSTORAGE_USER_NAME=Q-storage User
QSTORAGE_USER_EMAIL=qstorage@example.com
QSTORAGE_USER_REGISTERED_AT=2026-01-01
QSTORAGE_USER_COUNTRY=IT

# Optional legacy custom cloud backend
QMAP_API_TOKEN=
