# Required by q-map frontend provider "Q-cumber"
QCUMBER_BACKEND_TOKEN=qcumber-dev-token

# Optional JWT claim-based auth mode (takes precedence over QCUMBER_BACKEND_TOKEN when enabled).
QCUMBER_JWT_AUTH_ENABLED=false
QCUMBER_JWT_HS256_SECRETS=
QCUMBER_JWT_ALLOWED_ISSUERS=
QCUMBER_JWT_ALLOWED_AUDIENCES=
QCUMBER_JWT_REQUIRE_AUDIENCE=false
QCUMBER_JWT_ROLES_CLAIM_PATHS=roles,realm_access.roles,resource_access.q-map.roles
QCUMBER_JWT_ALLOWED_SUBJECTS=
QCUMBER_JWT_READ_ROLES=

# Optional profile shown by /me
QCUMBER_USER_NAME=Q-cumber User
QCUMBER_USER_EMAIL=qcumber@example.com

# Local metadata/cache location
QCUMBER_DATA_DIR=./data
# Provider descriptor location
QCUMBER_PROVIDERS_DIR=./provider-descriptors

# PostGIS connection (QCUMBER_POSTGIS_DSN takes precedence if set)
QCUMBER_POSTGIS_DSN=
QCUMBER_POSTGIS_HOST=host.docker.internal
QCUMBER_POSTGIS_PORT=5434
QCUMBER_POSTGIS_DB=qvt
QCUMBER_POSTGIS_USER=qvt
QCUMBER_POSTGIS_PASSWORD=qvt

# Comma-separated CORS list
QCUMBER_CORS_ORIGINS=http://localhost:8081,http://localhost:8082
# AI hints cache TTL (seconds) used by dataset help/query metadata inference cache
QCUMBER_AI_HINTS_CACHE_TTL_SECONDS=3600
# Connection pool size (min/max connections kept alive)
QCUMBER_POSTGIS_POOL_MIN=1
QCUMBER_POSTGIS_POOL_MAX=5
# uvicorn worker processes (reload auto-disabled when > 1)
QCUMBER_WORKERS=1
