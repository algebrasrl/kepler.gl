# This image must build against the full kepler.gl repo root so local
# modifications outside examples/q-map are included exactly like Vite dev mode.
FROM node:20-bullseye AS builder

WORKDIR /app

RUN corepack enable

# Copy dependency manifests first so Docker can reuse install layers when
# only application source files change.
COPY .yarnrc.yml /app/.yarnrc.yml
COPY package.json /app/package.json
COPY yarn.lock /app/yarn.lock
COPY src/types/package.json /app/src/types/package.json
COPY src/constants/package.json /app/src/constants/package.json
COPY src/common-utils/package.json /app/src/common-utils/package.json
COPY src/utils/package.json /app/src/utils/package.json
COPY src/styles/package.json /app/src/styles/package.json
COPY src/localization/package.json /app/src/localization/package.json
COPY src/deckgl-layers/package.json /app/src/deckgl-layers/package.json
COPY src/deckgl-arrow-layers/package.json /app/src/deckgl-arrow-layers/package.json
COPY src/table/package.json /app/src/table/package.json
COPY src/layers/package.json /app/src/layers/package.json
COPY src/schemas/package.json /app/src/schemas/package.json
COPY src/cloud-providers/package.json /app/src/cloud-providers/package.json
COPY src/processors/package.json /app/src/processors/package.json
COPY src/tasks/package.json /app/src/tasks/package.json
COPY src/actions/package.json /app/src/actions/package.json
COPY src/effects/package.json /app/src/effects/package.json
COPY src/reducers/package.json /app/src/reducers/package.json
COPY src/components/package.json /app/src/components/package.json
COPY src/duckdb/package.json /app/src/duckdb/package.json
COPY src/ai-assistant/package.json /app/src/ai-assistant/package.json
COPY examples/q-map/package.json /app/examples/q-map/package.json
COPY examples/q-map/yarn.lock /app/examples/q-map/yarn.lock

# q-map production builds depend on both:
# - repo-root kepler.gl deps for aliased src/* packages
# - examples/q-map deps for the Vite app itself
RUN --mount=type=cache,target=/root/.yarn \
    yarn install --mode=skip-build
RUN --mount=type=cache,target=/root/.yarn \
    yarn --cwd examples/q-map install --mode=skip-build

COPY . /app

WORKDIR /app/examples/q-map

ARG VITE_MAPBOX_TOKEN=
ARG VITE_QMAP_AUTH_TOKEN_STORAGE_KEYS=qmap_gateway_jwt,qmap_auth_token,qmap_access_token
ARG VITE_QMAP_AUTH_ALLOW_OPAQUE_BEARER=false
ARG VITE_QMAP_AI_PROXY_BASE=/api/q-assistant
ARG VITE_QCUMBER_CLOUD_API_BASE=/api/q-cumber
ARG VITE_QCUMBER_CLOUD_DISPLAY_NAME=Q-cumber
ARG VITE_QCUMBER_CLOUD_MANAGEMENT_URL=/api/q-cumber/maps
ARG VITE_QSTORAGE_CLOUD_API_BASE=/api/q-storage
ARG VITE_QSTORAGE_CLOUD_DISPLAY_NAME=Le mie mappe
ARG VITE_QSTORAGE_CLOUD_MANAGEMENT_URL=/api/q-storage/maps
ARG VITE_QCUMBER_TILESET_BASE=/api/q-cumber

ENV VITE_MAPBOX_TOKEN=$VITE_MAPBOX_TOKEN
ENV VITE_QMAP_AUTH_TOKEN_STORAGE_KEYS=$VITE_QMAP_AUTH_TOKEN_STORAGE_KEYS
ENV VITE_QMAP_AUTH_ALLOW_OPAQUE_BEARER=$VITE_QMAP_AUTH_ALLOW_OPAQUE_BEARER
ENV VITE_QMAP_AI_PROXY_BASE=$VITE_QMAP_AI_PROXY_BASE
ENV VITE_QCUMBER_CLOUD_API_BASE=$VITE_QCUMBER_CLOUD_API_BASE
ENV VITE_QCUMBER_CLOUD_DISPLAY_NAME=$VITE_QCUMBER_CLOUD_DISPLAY_NAME
ENV VITE_QCUMBER_CLOUD_MANAGEMENT_URL=$VITE_QCUMBER_CLOUD_MANAGEMENT_URL
ENV VITE_QSTORAGE_CLOUD_API_BASE=$VITE_QSTORAGE_CLOUD_API_BASE
ENV VITE_QSTORAGE_CLOUD_DISPLAY_NAME=$VITE_QSTORAGE_CLOUD_DISPLAY_NAME
ENV VITE_QSTORAGE_CLOUD_MANAGEMENT_URL=$VITE_QSTORAGE_CLOUD_MANAGEMENT_URL
ENV VITE_QCUMBER_TILESET_BASE=$VITE_QCUMBER_TILESET_BASE

RUN yarn build

FROM nginx:alpine

COPY examples/q-map/docker/nginx.ui.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/examples/q-map/dist /usr/share/nginx/html
COPY examples/q-map/docker/run-qmap-ui.sh /etc/q-map-ui/run-qmap-ui.sh

EXPOSE 8081

CMD ["/bin/sh", "/etc/q-map-ui/run-qmap-ui.sh"]
